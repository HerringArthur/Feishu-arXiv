# OpenAI-compatible LLM
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Daily digest: Feishu custom bot webhook
FEISHU_WEBHOOK=

# Reading/setup results: Feishu custom app bot
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_RECEIVE_ID=
FEISHU_RECEIVE_ID_TYPE=open_id

# Optional high-quality MinerU parsing; agent API is used as fallback
MINERU_TOKEN=
OCR_PAGE_LIMIT=20
OCR_TIMEOUT_SECONDS=600
